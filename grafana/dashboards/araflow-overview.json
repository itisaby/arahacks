          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Tool P95 Latency",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": { "tool_name": "Tool", "Value": "P95 Duration" }
          }
        }
      ],
      "type": "table"
    },
